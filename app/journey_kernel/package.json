{
  "name": "journey-kernel",
  "version": "0.1.2",
  "description": "WebView and native part of the MemoLanes app",
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "rimraf dist pkg && webpack --mode production",
    "preview": "rimraf dist pkg && webpack serve --mode production",
    "dev": "rimraf dist pkg && webpack serve --mode development",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,html}\"",
    "check-format": "prettier --check \"**/*.{js,jsx,ts,tsx,html}\"",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "maplibre-gl": "^5.16.0",
    "maplibregl-mapbox-request-transformer": "^0.0.3",
    "mathjs": "^15.0.0",
    "ua-parser-js": "^2.0.7",
    "vconsole": "^3.15.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@wasm-tool/wasm-pack-plugin": "^1.7.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.4",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  }
}
